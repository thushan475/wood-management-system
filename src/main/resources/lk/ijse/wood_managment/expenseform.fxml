<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane minHeight="622.0" minWidth="1104.0" prefHeight="622.0" prefWidth="1104.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.wood_managment.Controller.ExpenseFormController">

   <children>
      <ImageView fitHeight="761.0" fitWidth="1175.0" layoutX="-30.0" layoutY="-139.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@../../../images/11.jpg" />
         </image>
      </ImageView>

      <Label layoutX="467.0" layoutY="30.0" text="Expense" textFill="#f5efef" underline="true">
         <font>
            <Font name="DejaVu Serif Bold" size="36.0" />
         </font>
      </Label>

      <Label layoutX="51.0" layoutY="115.0" text="Expense Type" textFill="#f8f4f4">
         <font>
            <Font name="DejaVu Serif Bold" size="18.0" />
         </font>
      </Label>
      <ComboBox fx:id="cmbExpenseType" layoutX="238.0" layoutY="112.0" prefHeight="26.0" prefWidth="162.0" />

      <Label layoutX="51.0" layoutY="168.0" text="Description" textFill="#f8f4f4">
         <font>
            <Font name="DejaVu Serif Bold" size="18.0" />
         </font>
      </Label>
      <TextField fx:id="txtDescription" layoutX="238.0" layoutY="165.0" />

      <Label layoutX="50.0" layoutY="222.0" text="Amount" textFill="#f8f4f4">
