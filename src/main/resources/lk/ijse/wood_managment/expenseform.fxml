            <TableColumn fx:id="colWoodId" prefWidth="75.0" text="Wood Id" />
            <TableColumn fx:id="colExpenseType" prefWidth="106.0" text="Expense Type" />
            <TableColumn fx:id="colDescription" prefWidth="123.0" text="Description" />
