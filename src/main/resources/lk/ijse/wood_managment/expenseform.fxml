      <DatePicker fx:id="dpExpenseDate" layoutX="238.0" layoutY="274.0" prefHeight="26.0" prefWidth="162.0" />

      <Button fx:id="add" layoutX="800.0" layoutY="74.0" mnemonicParsing="false" onAction="#btnAdd" prefHeight="46.0" prefWidth="129.0" style="-fx-background-color: yellow;" text="Add">
         <font>
            <Font name="DejaVu Serif Bold" size="24.0" />
         </font>
      </Button>

      <Button fx:id="update" layoutX="800.0" layoutY="135.0" mnemonicParsing="false" onAction="#btnupdate" style="-fx-background-color: green;" text="Update">
         <font>
            <Font name="DejaVu Serif Bold" size="24.0" />
         </font>
      </Button>

      <Button fx:id="delete" layoutX="800.0" layoutY="189.0" mnemonicParsing="false" onAction="#btndelete" prefHeight="46.0" prefWidth="129.0" style="-fx-background-color: red;" text="Delete">
         <font>
            <Font name="DejaVu Serif Bold" size="24.0" />
         </font>
      </Button>

      <Button fx:id="search" layoutX="800.0" layoutY="243.0" mnemonicParsing="false" onAction="#btnsearch" prefHeight="46.0" prefWidth="129.0" style="-fx-background-color: blue;" text="Search" textFill="#f2f2f2">
         <font>
            <Font name="DejaVu Serif Bold" size="24.0" />
         </font>
      </Button>

      <Button fx:id="back" layoutX="800.0" layoutY="298.0" mnemonicParsing="false" onAction="#btnBack" prefHeight="44.0" prefWidth="129.0" text="Back">
