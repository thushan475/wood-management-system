            <TableColumn fx:id="colWidth" prefWidth="94.0" text="Width" />
            <TableColumn fx:id="colLength" minWidth="0.0" prefWidth="86.0" text="Length" />
            <TableColumn fx:id="colQtyPrice" prefWidth="125.0" text="Qty Price" />
            <TableColumn fx:id="colExpenseDate" prefWidth="119.0" text="Expense Date" />
            <TableColumn fx:id="colAmount" prefWidth="163.0" text="Amount" />
         </columns>
      </TableView>
