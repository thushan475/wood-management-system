<AnchorPane minHeight="622.0" minWidth="1104.0" prefHeight="622.0" prefWidth="1104.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.wood_managment.Controller.EmployeeFormController">
