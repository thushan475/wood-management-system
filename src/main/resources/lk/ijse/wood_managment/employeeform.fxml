                    <TableColumn fx:id="colUserId" prefWidth="123.0" text="User Id" />
                    <TableColumn fx:id="colName" prefWidth="224.0" text="Name" />
                    <TableColumn fx:id="colRole" prefWidth="163.0" text="Role" />
