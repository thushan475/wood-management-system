<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="622.0" prefWidth="1104.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.wood_management.controller.ExpenseTypeFormController">

   <children>

      <ImageView fitHeight="743.0" fitWidth="1172.0" layoutX="-9.0" layoutY="-121.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@../../../images/11.jpg" />
         </image>
      </ImageView>

      <Text fill="WHITE" layoutX="358.0" layoutY="60.0" text="Expense Type" underline="true">
         <font>
            <Font size="36.0" />
         </font>
      </Text>

      <Text fill="WHITE" layoutX="55.0" layoutY="171.0" text="Expense ID">
         <font>
            <Font name="DejaVu Serif Bold" size="22.0" />
         </font>
      </Text>

      <TextField fx:id="txtExpenseId" layoutX="293.0" layoutY="150.0" />

      <Text fill="WHITE" layoutX="55.0" layoutY="230.0" text="Expense Name">
         <font>
            <Font name="DejaVu Serif Bold" size="22.0" />
         </font>
      </Text>

      <TextField fx:id="txtExpenseName" layoutX="293.0" layoutY="209.0" />

      <Button fx:id="btnAdd" layoutX="855.0" layoutY="86.0" onAction="#add" prefHeight="49.0" prefWidth="147.0" style="-fx-background-color: yellow;" text="Add">
         <font>
            <Font name="DejaVu Serif Bold" size="18.0" />
         </font></Button>

      <Button fx:id="btnUpdate" layoutX="855.0" layoutY="148.0" onAction="#update" prefHeight="49.0" prefWidth="147.0" style="-fx-background-color: green;" text="Update" textFill="#eeecec">
         <font>
            <Font name="DejaVu Serif Bold" size="18.0" />
         </font></Button>

      <Button fx:id="btnSearch" layoutX="855.0" layoutY="212.0" onAction="#search" prefHeight="49.0" prefWidth="147.0" style="-fx-background-color: blue;" text="Search" textFill="#f8f3f3">
         <font>
            <Font name="DejaVu Serif Bold" size="18.0" />
         </font></Button>

      <Button fx:id="btnDelete" layoutX="855.0" layoutY="274.0" onAction="#delete" prefHeight="49.0" prefWidth="147.0" style="-fx-background-color: red;" text="Delete" textFill="#f8f3f3">
         <font>
            <Font name="DejaVu Serif Bold" size="18.0" />
         </font></Button>

      <TableView fx:id="tblExpense" layoutX="41.0" layoutY="359.0" onMouseClicked="#clickExpense" prefHeight="236.0" prefWidth="582.0">

         <columns>
            <TableColumn fx:id="colId" prefWidth="290.0" text="Expense ID" />
            <TableColumn fx:id="colName" prefWidth="290.0" text="Expense Name" />
         </columns>
      </TableView>

      <Button fx:id="btnBack" layoutX="855.0" layoutY="336.0" onAction="#back" prefHeight="49.0" prefWidth="147.0" text="Back">
         <font>
            <Font name="DejaVu Serif Bold" size="18.0" />
         </font></Button>

   </children>
</AnchorPane>
