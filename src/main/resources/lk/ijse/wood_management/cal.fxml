<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="524.0" prefWidth="400.0" style="-fx-background-color: black;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.wood_management.controller.CalculatorController">
    <children>
        <TextField fx:id="displayField" alignment="CENTER_RIGHT" layoutX="8.0" layoutY="23.0" prefHeight="74.0" prefWidth="384.0">
            <font>
                <Font size="32.0" />
            </font>
        </TextField>
        <AnchorPane layoutX="7.0" layoutY="100.0" prefHeight="422.0" prefWidth="384.0">
            <children>
                <Button layoutX="10.0" layoutY="14.0" mnemonicParsing="false" onAction="#numSevenClick" prefHeight="74.0" prefWidth="74.0" style="-fx-background-color: yellow;" text="7">
                    <font>
                        <Font name="System Bold" size="24.0" />
                    </font></Button>
                <Button layoutX="107.0" layoutY="14.0" mnemonicParsing="false" onAction="#numEightClick" prefHeight="74.0" prefWidth="74.0" style="-fx-background-color: yellow;" text="8">
                    <font>
                        <Font name="System Bold" size="24.0" />
                    </font></Button>
                <Button layoutX="202.0" layoutY="14.0" mnemonicParsing="false" onAction="#numNineClick" prefHeight="74.0" prefWidth="74.0" style="-fx-background-color: yellow;" text="9">
                    <font>
                        <Font name="System Bold" size="24.0" />
                    </font></Button>
                <Button layoutX="298.0" layoutY="14.0" mnemonicParsing="false" onAction="#modulus" prefHeight="74.0" prefWidth="74.0" style="-fx-background-color: orange;" text="\%">
                    <font>
                        <Font size="30.0" />
                    </font></Button>
                <Button layoutX="10.0" layoutY="98.0" mnemonicParsing="false" onAction="#numFourClick" prefHeight="74.0" prefWidth="74.0" style="-fx-background-color: yellow;" text="4">
                    <font>
                        <Font name="System Bold" size="24.0" />
                    </font></Button>
                <Button layoutX="10.0" layoutY="183.0" mnemonicParsing="false" onAction="#numOneClick" prefHeight="74.0" prefWidth="74.0" style="-fx-background-color: yellow;" text="1">
                    <font>
                        <Font name="System Bold" size="24.0" />
                    </font></Button>
                <Button layoutX="10.0" layoutY="275.0" mnemonicParsing="false" onAction="#numZeroClick" prefHeight="74.0" prefWidth="74.0" style="-fx-background-color: yellow;" text="0">
                    <font>
                        <Font name="System Bold" size="24.0" />
                    </font></Button>
                <Button layoutX="107.0" layoutY="98.0" mnemonicParsing="false" onAction="#numFiveClick" prefHeight="74.0" prefWidth="74.0" style="-fx-background-color: yellow;" text="5">
                    <font>
                        <Font name="System Bold" size="24.0" />
                    </font></Button>
                <Button layoutX="107.0" layoutY="183.0" mnemonicParsing="false" onAction="#numTwoClick" prefHeight="74.0" prefWidth="74.0" style="-fx-background-color: yellow;" text="2">
                    <font>
                        <Font name="System Bold" size="24.0" />
                    </font></Button>
                <Button layoutX="107.0" layoutY="275.0" mnemonicParsing="false" onAction="#decimalClick" prefHeight="74.0" prefWidth="74.0" style="-fx-background-color: orange;" text=".">
                    <font>
                        <Font size="30.0" />
                    </font></Button>
                <Button layoutX="202.0" layoutY="98.0" mnemonicParsing="false" onAction="#numSixClick" prefHeight="74.0" prefWidth="74.0" style="-fx-background-color: yellow;" text="6">
                    <font>
                        <Font name="System Bold" size="24.0" />
                    </font></Button>
                <Button layoutX="202.0" layoutY="183.0" mnemonicParsing="false" onAction="#numThreeClick" prefHeight="74.0" prefWidth="74.0" style="-fx-background-color: yellow;" text="3">
                    <font>
                        <Font name="System Bold" size="24.0" />
                    </font></Button>
                <Button layoutX="202.0" layoutY="275.0" mnemonicParsing="false" onAction="#additionOperator" prefHeight="74.0" prefWidth="74.0" style="-fx-background-color: orange;" text="+">
                    <font>
                        <Font size="30.0" />
                    </font></Button>
                <Button layoutX="298.0" layoutY="98.0" mnemonicParsing="false" onAction="#divOperator" prefHeight="74.0" prefWidth="74.0" style="-fx-background-color: orange;" text="/">
                    <font>
                        <Font size="30.0" />
                    </font></Button>
                <Button layoutX="298.0" layoutY="183.0" mnemonicParsing="false" onAction="#mulOperator" prefHeight="74.0" prefWidth="74.0" style="-fx-background-color: orange;" text="*">
                    <font>
                        <Font size="30.0" />
