                    <font>
                        <Font size="30.0" />
                    </font></Button>
                <Button fx:id="clear" layoutX="10.0" layoutY="360.0" mnemonicParsing="false" onAction="#clear" prefHeight="62.0" prefWidth="170.0" style="-fx-background-color: orange;" text="C">
                    <font>
                        <Font size="30.0" />
                    </font>
                </Button>
