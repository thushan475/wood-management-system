<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
			  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
			  xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
			  name="BillInvoice"
			  pageWidth="842"
			  pageHeight="595"
			  orientation="Landscape"
			  columnWidth="802"
			  leftMargin="20"
			  rightMargin="20"
			  topMargin="20"
			  bottomMargin="20">

	<parameter name="ORDER_ID" class="java.lang.Integer"/>

	<queryString>
		<![CDATA[SELECT
                o.order_id AS orderId,
                o.customer_id AS customerId,
                o.order_date AS orderDate,
                oi.quantity AS quantity,
                oi.amount AS totalAmount,
                o.description AS description,
                oi.timber_id AS timberId,
                oi.width AS width,
                oi.length AS length,
                oi.species AS species
            FROM customer_order o
            JOIN customer_order_items oi ON o.order_id = oi.order_id
            WHERE o.order_id = $P{ORDER_ID}]]>
	</queryString>

	<field name="orderId" class="java.lang.Integer"/>
	<field name="customerId" class="java.lang.Integer"/>
	<field name="orderDate" class="java.util.Date"/>
	<field name="quantity" class="java.lang.Double"/>
	<field name="totalAmount" class="java.lang.Double"/>
	<field name="description" class="java.lang.String"/>
	<field name="timberId" class="java.lang.Integer"/>
	<field name="width" class="java.lang.Double"/>
	<field name="length" class="java.lang.Double"/>
	<field name="species" class="java.lang.String"/>

	<!-- Variable to calculate grand total -->
	<variable name="grandTotal" class="java.lang.Double" calculation="Sum">
		<variableExpression><![CDATA[$F{totalAmount}]]></variableExpression>
	</variable>

	<title>
		<band height="60">
			<staticText>
				<reportElement x="0" y="10" width="802" height="40"/>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font size="24" isBold="true"/>
				</textElement>
				<text><![CDATA[Bill / Invoice]]></text>
			</staticText>
		</band>
	</title>

	<columnHeader>
		<band height="30">
			<staticText>
				<reportElement x="0" y="0" width="60" height="30"/>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font isBold="true"/>
				</textElement>
				<text><![CDATA[Order ID]]></text>
			</staticText>
			<staticText>
				<reportElement x="60" y="0" width="80" height="30"/>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font isBold="true"/>
				</textElement>
				<text><![CDATA[Customer ID]]></text>
			</staticText>
			<staticText>
				<reportElement x="140" y="0" width="100" height="30"/>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font isBold="true"/>
				</textElement>
				<text><![CDATA[Order Date]]></text>
			</staticText>
			<staticText>
				<reportElement x="240" y="0" width="70" height="30"/>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font isBold="true"/>
				</textElement>
				<text><![CDATA[Quantity]]></text>
			</staticText>
			<staticText>
				<reportElement x="310" y="0" width="90" height="30"/>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font isBold="true"/>
				</textElement>
				<text><![CDATA[Amount]]></text>
			</staticText>
			<staticText>
				<reportElement x="400" y="0" width="120" height="30"/>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font isBold="true"/>
				</textElement>
				<text><![CDATA[Description]]></text>
			</staticText>
			<staticText>
				<reportElement x="520" y="0" width="70" height="30"/>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font isBold="true"/>
				</textElement>
				<text><![CDATA[Timber ID]]></text>
			</staticText>
			<staticText>
				<reportElement x="590" y="0" width="70" height="30"/>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font isBold="true"/>
				</textElement>
				<text><![CDATA[Width]]></text>
			</staticText>
			<staticText>
				<reportElement x="660" y="0" width="70" height="30"/>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font isBold="true"/>
				</textElement>
				<text><![CDATA[Length]]></text>
			</staticText>
			<staticText>
				<reportElement x="730" y="0" width="72" height="30"/>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font isBold="true"/>
				</textElement>
				<text><![CDATA[Species]]></text>
			</staticText>
		</band>
	</columnHeader>

	<detail>
		<band height="25">
			<textField>
				<reportElement x="0" y="0" width="60" height="25"/>
				<textElement textAlignment="Center" verticalAlignment="Middle"/>
				<textFieldExpression><![CDATA[$F{orderId}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="60" y="0" width="80" height="25"/>
				<textElement textAlignment="Center" verticalAlignment="Middle"/>
				<textFieldExpression><![CDATA[$F{customerId}]]></textFieldExpression>
			</textField>
			<textField pattern="yyyy-MM-dd">
				<reportElement x="140" y="0" width="100" height="25"/>
				<textElement textAlignment="Center" verticalAlignment="Middle"/>
				<textFieldExpression><![CDATA[$F{orderDate}]]></textFieldExpression>
			</textField>
			<textField pattern="#,##0.00">
				<reportElement x="240" y="0" width="70" height="25"/>
				<textElement textAlignment="Center" verticalAlignment="Middle"/>
				<textFieldExpression><![CDATA[$F{quantity}]]></textFieldExpression>
			</textField>
			<textField pattern="#,##0.00">
				<reportElement x="310" y="0" width="90" height="25"/>
				<textElement textAlignment="Center" verticalAlignment="Middle"/>
				<textFieldExpression><![CDATA[$F{totalAmount}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="400" y="0" width="120" height="25"/>
				<textElement textAlignment="Center" verticalAlignment="Middle"/>
				<textFieldExpression><![CDATA[$F{description}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="520" y="0" width="70" height="25"/>
				<textElement textAlignment="Center" verticalAlignment="Middle"/>
				<textFieldExpression><![CDATA[$F{timberId}]]></textFieldExpression>
			</textField>
			<textField pattern="#,##0.00">
				<reportElement x="590" y="0" width="70" height="25"/>
				<textElement textAlignment="Center" verticalAlignment="Middle"/>
				<textFieldExpression><![CDATA[$F{width}]]></textFieldExpression>
			</textField>
			<textField pattern="#,##0.00">
				<reportElement x="660" y="0" width="70" height="25"/>
				<textElement textAlignment="Center" verticalAlignment="Middle"/>
				<textFieldExpression><![CDATA[$F{length}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="730" y="0" width="72" height="25"/>
				<textElement textAlignment="Center" verticalAlignment="Middle"/>
				<textFieldExpression><![CDATA[$F{species}]]></textFieldExpression>
			</textField>
		</band>
	</detail>

	<summary>
		<band height="60">
			<line>
				<reportElement x="0" y="0" width="802" height="1"/>
				<graphicElement>
					<pen lineWidth="2"/>
				</graphicElement>
			</line>
			<staticText>
				<reportElement x="200" y="20" width="110" height="30"/>
				<textElement textAlignment="Right" verticalAlignment="Middle">
					<font size="14" isBold="true"/>
				</textElement>
				<text><![CDATA[Grand Total:]]></text>
			</staticText>
			<textField pattern="#,##0.00">
				<reportElement x="310" y="20" width="90" height="30"/>
				<textElement textAlignment="Right" verticalAlignment="Middle">
					<font size="14" isBold="true"/>
				</textElement>
				<textFieldExpression><![CDATA[$V{grandTotal}]]></textFieldExpression>
			</textField>
		</band>
	</summary>

</jasperReport>